# .env.example

# Server Configuration
SERVER_HOST=
SERVER_PORT=
ENVIRONMENT=
PUBLIC_URL=
SHUTDOWN_TIMEOUT=
READ_TIMEOUT=
WRITE_TIMEOUT=
MAX_HEADER_BYTES=
FRONTEND_URL=

# Database Configuration (Required)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_MODE=
DB_MAX_OPEN_CONNS=
DB_MAX_IDLE_CONNS=
DB_CONN_MAX_LIFETIME=
DB_CONN_MAX_IDLE_TIME=

# MQTT Configuration (Required)
MQTT_BROKER=
MQTT_PORT=
MQTT_CLIENT_ID=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=campus/probes/telemetry
MQTT_COMMAND_TOPIC=campus/probes/+/cmd
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_KEEP_ALIVE=60s
MQTT_CONNECT_TIMEOUT=10s
MQTT_AUTO_RECONNECT=true

# Security Configuration
JWT_SECRET=campus_monitor_secret_change_in_production
JWT_EXPIRATION_HOURS=24
API_KEY_HEADER=X-API-Key
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
RATE_LIMIT_PER_MINUTE=1000
ENABLE_RATE_LIMIT=true
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h
ENABLE_LOCAL_LOGIN=true
ENABLE_REGISTRATION=true
ENABLE_ADMIN_REGISTRATION=true
REQUIRE_2FA=false

## LDAP stuff
LDAP_ENABLED=
LDAP_HOST=
LDAP_PORT=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_BASE=
LDAP_USER_SEARCH_FILTER=
LDAP_INSECURE_SKIP_VERIFY=
LDAP_FALLBACK_TO_LOCAL=

# OAUTH stuff
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=
POCKETID_USERINFO_URL=
POCKETID_TOKEN_URL=
POCKETID_AUTH_URL=
POCKETID_SCOPES=


# Logging Configuration
LOG_LEVEL=
LOG_MODE=
LOG_FILE_PATH=
LOG_USE_COLORS=

CERT_DIR=