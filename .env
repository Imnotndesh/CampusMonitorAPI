# .env.example

# =======================================
# Server Configuration
# =======================================
SERVER_HOST=0.0.0.0
SERVER_PORT=9080
ENVIRONMENT=development
PUBLIC_URL=http://localhost:9080
SHUTDOWN_TIMEOUT=15s
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
MAX_HEADER_BYTES=1048576

# =======================================
# Database Configuration (Required)
# =======================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=campus_admin
DB_PASSWORD=campus_secure_2024
DB_NAME=campus_monitor
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# =======================================
# MQTT Configuration (Required)
# =======================================
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=campus-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=campus/probes/telemetry
MQTT_COMMAND_TOPIC=campus/probes/+/cmd
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_KEEP_ALIVE=60s
MQTT_CONNECT_TIMEOUT=10s
MQTT_AUTO_RECONNECT=true

# =======================================
# Security Configuration
# =======================================
JWT_SECRET=campus_monitor_secret_change_in_production
JWT_EXPIRATION_HOURS=24
API_KEY_HEADER=X-API-Key
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
RATE_LIMIT_PER_MINUTE=100
ENABLE_RATE_LIMIT=true
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h
ENABLE_LOCAL_LOGIN=true
ENABLE_REGISTRATION=true
REQUIRE_2FA=false

# OAUTH stuff
POCKETID_CLIENT_ID=2b293147-0670-44cc-9dcf-c60518146b70
POCKETID_CLIENT_SECRET=CWBOPdMFkSYeDpE4sBaLt8qE7eqx607d
POCKETID_AUTH_URL=http://localhost:1411/authorize
POCKETID_TOKEN_URL=http://localhost:1411/api/oauth/token
POCKETID_USERINFO_URL=http://localhost:1411/api/oauth/userinfo
POCKETID_SCOPES=openid,profile,email

# =======================================
# Logging Configuration
# =======================================
LOG_LEVEL=info
LOG_MODE=normal
LOG_FILE_PATH=logs/campus-monitor.log
LOG_USE_COLORS=true

# Remember this should be addressed when making this into a docker container
CERT_DIR=certs